# Automaton Auditor - Environment Variables
# Copy this file to .env and fill in your values.

# LangSmith Tracing (recommended for debugging multi-agent chains)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=automaton-auditor
LANGCHAIN_API_KEY=your_key_here

# LLM provider: "ollama" (local, free) or "gemini" (cloud, free tier has quota)
LLM_PROVIDER=ollama

# Google Gemini (only when LLM_PROVIDER=gemini)
GOOGLE_API_KEY=your_key_here
# Get your free key at: https://aistudio.google.com/apikey

# Model selection
# Ollama: llama3.2, mistral, qwen2.5, etc. (run: ollama pull llama3.2)
# Gemini: gemini-2.0-flash
AUDITOR_LLM_MODEL=llama3.2
VISION_LLM_MODEL=gemini-1.5-flash
